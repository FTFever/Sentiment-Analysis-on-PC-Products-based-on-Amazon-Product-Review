"""
STEP 4: Aspect-Based Sentiment Analysis
-----------------------------------------
Purpose : Identify specific aspects mentioned in each review (e.g. battery,
          display, performance, price) and determine the sentiment toward
          each aspect individually.

Why Mistral via Ollama for this task?
  - Aspect-based sentiment requires reading the review, identifying which
    aspects are mentioned, and reasoning about the sentiment for each one —
    this is a complex language understanding task where a generative LLM
    excels over a simple classifier.
  - Ollama makes it easy to run Mistral entirely locally with no API cost.
  - The model is prompted with a structured JSON output format so results
    are easy to parse programmatically.

Prerequisites:
  1. Install Ollama: https://ollama.com
  2. Pull Mistral:   ollama pull mistral
  3. pip install ollama pandas tqdm

Input   : test.csv (or any CSV with a 'full_text' column)
Output  : aspect_sentiment_results.csv
"""

import pandas as pd
import json
import re
from tqdm import tqdm
import ollama

# ── Configuration ────────────────────────────────────────────────────────────
INPUT_FILE   = "test.csv"
OUTPUT_FILE  = "aspect_sentiment_results.csv"
MODEL_NAME   = "mistral"   # Must be pulled via: ollama pull mistral
BATCH_SIZE   = 50          # Process N reviews at a time before saving

# PC-specific aspects we care about
PC_ASPECTS = [
    "battery life",
    "performance / speed",
    "display / screen",
    "keyboard / trackpad",
    "build quality",
    "price / value",
    "customer service",
    "software / OS",
    "portability / weight",
    "storage"
]
# ─────────────────────────────────────────────────────────────────────────────


# ── Prompt Template ───────────────────────────────────────────────────────────

def build_prompt(review_text):
    """
    Builds a structured prompt that instructs Mistral to:
    1. Identify which PC aspects are mentioned in the review
    2. Determine the sentiment for each mentioned aspect
    3. Return results as clean JSON
    """
    aspects_list = "\n".join(f"- {a}" for a in PC_ASPECTS)

    prompt = f"""You are an expert product review analyst specializing in PC and laptop reviews.

Analyze the following customer review and identify which aspects are mentioned.
For each mentioned aspect, determine the sentiment expressed (positive, negative, or neutral).
Only include aspects that are explicitly or clearly implicitly mentioned.

Aspects to look for:
{aspects_list}

Review:
\"\"\"{review_text}\"\"\"

Respond ONLY with a valid JSON object in this exact format, nothing else:
{{
  "aspects": [
    {{
      "aspect": "<aspect name>",
      "sentiment": "<positive|negative|neutral>",
      "evidence": "<short quote or phrase from the review that supports this>"
    }}
  ],
  "summary": "<one sentence overall takeaway>"
}}

If no aspects are found, return: {{"aspects": [], "summary": "No specific aspects mentioned."}}
"""
    return prompt


# ── Inference ─────────────────────────────────────────────────────────────────

def analyze_aspects(review_text):
    """
    Sends a review to the local Mistral model via Ollama and parses the result.
    Returns a dict with aspect-level sentiment or an error dict on failure.
    """
    prompt = build_prompt(review_text)

    try:
        response = ollama.chat(
            model=MODEL_NAME,
            messages=[{"role": "user", "content": prompt}],
            options={"temperature": 0.0}   # Deterministic output for consistency
        )
        raw = response['message']['content'].strip()

        # Extract JSON block in case the model adds extra text
        json_match = re.search(r'\{.*\}', raw, re.DOTALL)
        if json_match:
            return json.loads(json_match.group())
        else:
            return {"aspects": [], "summary": "Could not parse response.", "error": raw}

    except json.JSONDecodeError:
        return {"aspects": [], "summary": "JSON parse error.", "error": raw}
    except Exception as e:
        return {"aspects": [], "summary": f"Error: {str(e)}", "error": str(e)}


# ── Batch Processing ──────────────────────────────────────────────────────────

def process_reviews(input_file, output_file):
    """
    Processes reviews in batches, saves progress incrementally so results
    are not lost if the process is interrupted.
    """
    df = pd.read_csv(input_file)
    print(f"Loaded {len(df):,} reviews for aspect analysis")
    print(f"Model: {MODEL_NAME} (via Ollama)\n")

    results = []

    for i, row in tqdm(df.iterrows(), total=len(df), desc="Analyzing aspects"):
        review_text = str(row.get('full_text', row.get('review_body', '')))

        # Skip very short reviews — not enough content for aspect analysis
        if len(review_text.strip()) < 20:
            results.append({
                "review_text":      review_text,
                "overall_sentiment": row.get('sentiment', 'unknown'),
                "aspects_json":     json.dumps({"aspects": [], "summary": "Too short"}),
                "num_aspects":      0,
                "aspect_summary":   "Too short"
            })
            continue

        analysis = analyze_aspects(review_text)

        results.append({
            "review_text":       review_text[:300],   # Truncate for readability in CSV
            "overall_sentiment": row.get('sentiment', 'unknown'),
            "aspects_json":      json.dumps(analysis),
            "num_aspects":       len(analysis.get('aspects', [])),
            "aspect_summary":    analysis.get('summary', '')
        })

        # Save progress in batches
        if (i + 1) % BATCH_SIZE == 0:
            pd.DataFrame(results).to_csv(output_file, index=False)
            print(f"  Progress saved: {i + 1} reviews processed")

    # Final save
    results_df = pd.DataFrame(results)
    results_df.to_csv(output_file, index=False)
    print(f"\nAspect analysis complete! Results saved to: {output_file}")
    return results_df


# ── Aggregation & Reporting ───────────────────────────────────────────────────

def aggregate_aspect_sentiment(results_df):
    """
    Aggregates aspect-level sentiments across all reviews to produce
    a summary showing which aspects are most frequently positive/negative.
    This is the key business insight output.
    """
    aspect_records = []

    for _, row in results_df.iterrows():
        try:
            analysis = json.loads(row['aspects_json'])
            for aspect_data in analysis.get('aspects', []):
                aspect_records.append({
                    "aspect":    aspect_data.get('aspect', ''),
                    "sentiment": aspect_data.get('sentiment', ''),
                    "evidence":  aspect_data.get('evidence', '')
                })
        except (json.JSONDecodeError, TypeError):
            continue

    if not aspect_records:
        print("No aspect data found to aggregate.")
        return

    aspects_df = pd.DataFrame(aspect_records)

    # Pivot to get sentiment counts per aspect
    summary = aspects_df.groupby(['aspect', 'sentiment']).size().unstack(fill_value=0)

    # Add total mentions and positive rate
    summary['total_mentions'] = summary.sum(axis=1)
    if 'positive' in summary.columns and 'negative' in summary.columns:
        summary['positive_rate'] = (summary['positive'] / summary['total_mentions'] * 100).round(1)
        summary['negative_rate'] = (summary['negative'] / summary['total_mentions'] * 100).round(1)

    summary = summary.sort_values('total_mentions', ascending=False)

    print("\n── Aspect-Based Sentiment Summary ───────────────────────────────")
    print(summary.to_string())
    print("─────────────────────────────────────────────────────────────────")

    summary.to_csv("aspect_summary.csv")
    print("\nAspect summary saved to: aspect_summary.csv")
    return summary


# ── Main ──────────────────────────────────────────────────────────────────────

if __name__ == "__main__":
    # Process reviews
    results_df = process_reviews(INPUT_FILE, OUTPUT_FILE)

    # Generate aggregated business insights
    aggregate_aspect_sentiment(results_df)

    # Show a sample result
    print("\nSample aspect analysis result:")
    sample = results_df[results_df['num_aspects'] > 0].head(1)
    if not sample.empty:
        print(f"\nReview: {sample.iloc[0]['review_text'][:200]}...")
        print(f"Overall: {sample.iloc[0]['overall_sentiment']}")
        analysis = json.loads(sample.iloc[0]['aspects_json'])
        print(f"Summary: {analysis.get('summary')}")
        print("Aspects found:")
        for a in analysis.get('aspects', []):
            print(f"  [{a['sentiment'].upper()}] {a['aspect']} → \"{a['evidence']}\"")
