# ── 4. Visualizations ─────────────────────────────────────────────────────────

def generate_visualizations(test_df):
    """Creates a dashboard of charts summarizing the sentiment analysis."""
    fig = plt.figure(figsize=(16, 10))
    fig.suptitle("PC Product Review — Sentiment Analysis Dashboard", fontsize=16, fontweight='bold')
    gs = gridspec.GridSpec(2, 2, figure=fig, hspace=0.4, wspace=0.35)

    colors = {'positive': '#4CAF50', 'neutral': '#FFC107', 'negative': '#F44336'}

    # ── Chart 1: Overall sentiment pie chart ──
    ax1  = fig.add_subplot(gs[0, 0])
    dist = test_df['predicted_sentiment'].value_counts()
    ax1.pie(dist.values,
            labels=[l.capitalize() for l in dist.index],
            colors=[colors.get(l, '#999') for l in dist.index],
            autopct='%1.1f%%', startangle=90)
    ax1.set_title("Overall Sentiment Distribution")

    # ── Chart 2: Sentiment by star rating ──
    ax2 = fig.add_subplot(gs[0, 1])
    rating_sentiment = test_df.groupby(['star_rating', 'predicted_sentiment']).size().unstack(fill_value=0)
    rating_sentiment.plot(kind='bar', ax=ax2,
                          color=[colors.get(c, '#999') for c in rating_sentiment.columns])
    ax2.set_title("Predicted Sentiment by Star Rating")
    ax2.set_xlabel("Star Rating")
    ax2.set_ylabel("Count")
    ax2.tick_params(axis='x', rotation=0)
    ax2.legend(title="Sentiment")

    # ── Chart 3: Aspect sentiment heatmap ──
    ax3 = fig.add_subplot(gs[1, :])
    try:
        summary_df = pd.read_csv(ASPECT_SUMMARY_FILE, index_col=0)
        cols_to_plot = [c for c in ['positive', 'neutral', 'negative'] if c in summary_df.columns]
        if cols_to_plot:
            heatmap_data = summary_df[cols_to_plot].T
            sns.heatmap(heatmap_data, ax=ax3, cmap='RdYlGn', annot=True,
                        fmt='.0f', linewidths=0.5)
            ax3.set_title("Aspect-Based Sentiment Heatmap (count of mentions)")
            ax3.set_ylabel("Sentiment")
    except FileNotFoundError:
        ax3.text(0.5, 0.5, "Run Step 4 to generate aspect data",
                 ha='center', va='center', transform=ax3.transAxes)
        ax3.set_title("Aspect-Based Sentiment (Not yet generated)")

    plt.savefig("sentiment_dashboard.png", dpi=150, bbox_inches='tight')
    print("Dashboard saved to: sentiment_dashboard.png")


