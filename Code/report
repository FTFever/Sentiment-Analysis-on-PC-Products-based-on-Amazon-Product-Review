# ── 1. Overall Sentiment Report ───────────────────────────────────────────────

def overall_sentiment_report(test_df):
    """Generates overall sentiment distribution statistics."""
    print("Generating overall sentiment predictions...")
    results = predict_sentiment(test_df['full_text'].tolist())
    test_df['predicted_sentiment'] = [r['sentiment'] for r in results]
    test_df['confidence']          = [r['confidence'] for r in results]

    distribution = test_df['predicted_sentiment'].value_counts(normalize=True) * 100

    report_lines = [
        "═══════════════════════════════════════════════════════",
        "       PC PRODUCT SENTIMENT ANALYSIS — BUSINESS REPORT ",
        "═══════════════════════════════════════════════════════",
        "",
        "── 1. OVERALL CUSTOMER SENTIMENT ──────────────────────",
        f"   Total reviews analyzed : {len(test_df):,}",
        ""
    ]
    for label in ['positive', 'neutral', 'negative']:
        pct = distribution.get(label, 0)
        bar = '█' * int(pct / 2)
        report_lines.append(f"   {label.capitalize():10s} : {pct:5.1f}%  {bar}")

    avg_conf = test_df['confidence'].mean()
    report_lines.append(f"\n   Average prediction confidence: {avg_conf:.2%}")
    report_lines.append("")

    return report_lines, test_df


# ── 2. Aspect-Based Report ────────────────────────────────────────────────────

def aspect_sentiment_report():
    """Generates aspect-level sentiment statistics."""
    try:
        summary_df = pd.read_csv(ASPECT_SUMMARY_FILE, index_col=0)
    except FileNotFoundError:
        return ["   [Aspect summary file not found — run Step 4 first]", ""]

    report_lines = [
        "── 2. ASPECT-BASED SENTIMENT ──────────────────────────",
        "   (Ranked by number of mentions)",
        ""
    ]

    for aspect, row in summary_df.iterrows():
        total    = int(row.get('total_mentions', 0))
        pos_rate = row.get('positive_rate', 0)
        neg_rate = row.get('negative_rate', 0)
        neu_rate = 100 - pos_rate - neg_rate

        sentiment_indicator = ("✅ Strong positive" if pos_rate >= 70
                               else "⚠️  Mixed"        if pos_rate >= 40
                               else "❌ Mostly negative")

        report_lines.append(f"   {aspect:<30s} ({total:,} mentions)  {sentiment_indicator}")
        report_lines.append(f"   {'':30s} Positive: {pos_rate:.0f}%  Neutral: {neu_rate:.0f}%  Negative: {neg_rate:.0f}%")
        report_lines.append("")

    return report_lines


# ── 3. Key Findings ───────────────────────────────────────────────────────────

def key_findings_report(test_df):
    """Highlights the most actionable business findings."""
    try:
        summary_df = pd.read_csv(ASPECT_SUMMARY_FILE, index_col=0)
        top_positive = summary_df[summary_df.get('positive_rate', 0) >= 70].index.tolist()
        top_negative = summary_df[summary_df.get('negative_rate', 0) >= 40].index.tolist()
    except FileNotFoundError:
        top_positive, top_negative = [], []

    overall_dist = test_df['predicted_sentiment'].value_counts(normalize=True) * 100

    report_lines = [
        "── 3. KEY BUSINESS FINDINGS ───────────────────────────",
        ""
    ]

    # Overall health
    pos_pct = overall_dist.get('positive', 0)
    neg_pct = overall_dist.get('negative', 0)
    if pos_pct >= 60:
        report_lines.append(f"   ✅ Overall customer satisfaction is STRONG at {pos_pct:.1f}% positive.")
    elif pos_pct >= 40:
        report_lines.append(f"   ⚠️  Customer satisfaction is MODERATE at {pos_pct:.1f}% positive.")
    else:
        report_lines.append(f"   ❌ Customer satisfaction is LOW — only {pos_pct:.1f}% positive reviews.")

    if top_positive:
        report_lines.append(f"\n   Strongest aspects (customers are happy with):")
        for a in top_positive[:3]:
            report_lines.append(f"     • {a}")

    if top_negative:
        report_lines.append(f"\n   Weakest aspects (priority areas for improvement):")
        for a in top_negative[:3]:
            report_lines.append(f"     • {a}")

    report_lines += [
        "",
        "── 4. GENERAL RECOMMENDATIONS ─────────────────────────",
        ""
    ]
    if top_negative:
        report_lines.append(f"   1. Focus product development resources on improving:")
        for a in top_negative[:3]:
            report_lines.append(f"      → {a}")
    if top_positive:
        report_lines.append(f"\n   2. Leverage strengths in marketing materials:")
        for a in top_positive[:3]:
            report_lines.append(f"      → {a}")

    report_lines += [
        "",
        "   3. Monitor sentiment trends monthly to detect emerging issues early.",
        "   4. Cross-reference negative aspect reviews with low helpful_votes",
        "      to prioritize which complaints have the broadest customer impact.",
        "",
        "═══════════════════════════════════════════════════════",
        ""
    ]
    return report_lines


# ── 4. Targeted Strategy & Recommendations ────────────────────────────────────

def extract_positive_evidence(max_quotes_per_aspect=3):
    """
    Extracts real customer quotes for each positively-rated aspect from
    the raw aspect_sentiment_results.csv produced by Step 4.
    Returns a dict mapping aspect name to a list of positive evidence strings.
    """
    try:
        results_df = pd.read_csv(ASPECT_RESULTS_FILE)
        summary_df = pd.read_csv(ASPECT_SUMMARY_FILE, index_col=0)
    except FileNotFoundError:
        return {}

    if 'positive_rate' not in summary_df.columns:
        return {}

    strong_aspects = summary_df[summary_df['positive_rate'] >= 65].index.tolist()
    evidence_by_aspect = {aspect: [] for aspect in strong_aspects}

    for _, row in results_df.iterrows():
        try:
            analysis = json.loads(row['aspects_json'])
        except (json.JSONDecodeError, TypeError, KeyError):
            continue

        for item in analysis.get('aspects', []):
            aspect    = item.get('aspect', '')
            sentiment = item.get('sentiment', '')
            evidence  = item.get('evidence', '').strip()

            if (aspect in evidence_by_aspect
                    and sentiment == 'positive'
                    and len(evidence) > 10
                    and len(evidence_by_aspect[aspect]) < max_quotes_per_aspect):
                evidence_by_aspect[aspect].append(evidence)

    return {k: v for k, v in evidence_by_aspect.items() if v}


